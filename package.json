{
  "name": "vue3-enterprise-app",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev":          "vite",
    "build":        "vue-tsc --noEmit && vite build",
    "preview":      "vite preview",
    "typecheck":    "vue-tsc --noEmit",
    "lint":         "eslint . --ext .vue,.ts,.tsx --fix",
    "test":         "vitest run",
    "test:watch":   "vitest",
    "test:coverage":"vitest run --coverage"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "axios":        "^1.7.2",
    "element-plus": "^2.7.6",
    "idb":          "^8.0.0",
    "pinia":        "^2.1.7",
    "vue":          "^3.4.31",
    "vue-router":   "^4.3.3"
  },
  "devDependencies": {
    "@types/node":               "^20.14.9",
    "@unocss/reset":             "^0.61.0",
    "@vitejs/plugin-vue":        "^5.0.5",
    "@vitejs/plugin-vue-jsx":    "^4.0.0",
    "@vue/test-utils":           "^2.4.6",
    "eslint":                    "^9.0.0",
    "msw":                       "^2.3.1",
    "typescript":                "^5.5.0",
    "unocss":                    "^0.61.0",
    "unplugin-auto-import":      "^0.18.2",
    "unplugin-icons":            "^0.19.0",
    "unplugin-vue-components":   "^0.27.3",
    "vite":                      "^5.4.0",
    "vitest":                    "^2.0.3",
    "vue-tsc":                   "^2.0.26"
  }
}
