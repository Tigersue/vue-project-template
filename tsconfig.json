{
  "compilerOptions": {
    "target":               "ESNext",
    "module":               "ESNext",
    "moduleResolution":     "Bundler",
    "lib":                  ["ESNext","DOM","DOM.Iterable"],
    "strict":               true,
    "noUnusedLocals":       true,
    "noUnusedParameters":   true,
    "resolveJsonModule":    true,
    "isolatedModules":      true,
    "jsx":                  "preserve",
    "jsxImportSource":      "vue",
    "skipLibCheck":         true,
    "baseUrl":              ".",
    "paths": { "@/*": ["src/*"] }
  },
  "include": ["src/**/*.ts","src/**/*.d.ts","src/**/*.tsx","src/**/*.vue"],
  "exclude": ["node_modules","dist"]
}
